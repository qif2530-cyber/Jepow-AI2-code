# 阿里服务器环境变量配置

# 核心：将数据库和上传文件夹指向代码目录外的固定位置
DB_PATH=/home/admin/jepow_data/db.json
UPLOADS_PATH=/home/admin/jepow_data/uploads

# 安全密钥（建议修改为复杂的字符串）
JWT_SECRET=jepow_secure_2026_top_secret

# AI 配置（请填入您的阿里服务器可用的密钥）
GEMINI_API_KEY=
GEMINI_BASE_URL=

# 其他服务配置
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# 运行环境
NODE_ENV=production

# 桌面画布客户端连接的官网 API（默认 https://jepow.com）
VITE_JEPOW_WEB_ORIGIN=https://jepow.com
